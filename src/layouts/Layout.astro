---                          
import '../assets/styles/global.css';
import { AstroFont } from 'astro-font';
const { title } = Astro.props;
---             

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<AstroFont
			config={[
				{
					name: 'DM Sans',
					src: [],
					googleFontsURL: 'https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap',
					preload: true,
					display: 'swap',
					selector: 'body',
					fallback: 'sans-serif',
				},
			]}
		/>
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title ? `${title} |` : ''} Sergi Rodriguez</title>
	</head>
	<body>
		

    <!-- Header -->
    <header class="">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="#" class="text-lg font-semibold text-primary tracking-wide">
          Sergi Rodriguez
        </a>
        <nav>
          <ul class="flex gap-8">
            <li><a href="#" class="nav-link">Home</a></li>
            <li><a href="#projects" class="nav-link">Projects</a></li>
            <li><a href="#about" class="nav-link">About</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <slot />

    <!-- Footer -->
    <footer class="border-t border-border py-8">
      <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
        <a href="/privacy" class="text-sm text-muted hover:text-foreground transition-colors underline underline-offset-2">
          Privacy Policy
        </a>
        <p class="text-sm text-muted/70">
          &copy; 2026 Sergi Rodriguez. All rights reserved.
        </p>
      </div>
    </footer>
  </body>
</html>
