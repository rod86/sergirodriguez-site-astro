---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import heroImg from '@assets/img/hero-img.svg';

const homeProjects = [
  'intranet-alzamora',
  'afmi',
  'jobboard',
  'zoobarcelona',
];
const projects = await getCollection('projects', ({ id }) => {
  return homeProjects.includes(id);
}) as CollectionEntry<'projects'>[];
---

<Layout title="Home">
  <!-- Hero -->
    <section class="flex flex-col md:flex-row items-center gap-16 mb-18">
      <div class="flex-1 text-center md:text-left">
        <h1 class="text-5xl font-bold text-foreground leading-tight mb-6">
          I am a <br/><span class="text-primary">Full Stack Developer</span><br/>
        </h1>
        <p class="text-muted text-base leading-relaxed max-w-lg mb-10">
          With over 10 years of experience building with PHP, Node.js, TypeScript, Python and React,
          I craft scalable, high-performance web applications — from MVPs to enterprise-grade platforms.
          I care deeply about clean code, thoughtful architecture, and shipping things that last.
        </p>
        <div class="flex flex-wrap justify-center">
          <a href="/about" class="btn-primary">
            About Me
          </a>
        </div>

      </div>
      <div class="flex-1 flex justify-center">
        <Image src={heroImg} alt="Developer illustration" class="w-full max-w-md" />
      </div>
    </section>

    <!-- Projects -->
    <section>
      <h2 class="text-3xl font-bold text-foreground mb-12">Featured Projects</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {projects.map(project => (
          <article class="bg-surface rounded-xl overflow-hidden group flex flex-col">
            {project.data.image && (
              <div class="h-48 overflow-hidden">
                <Image src={project.data.image} alt={`${project.data.title} thumbnail`} class="w-full h-full object-cover"/>
              </div>
            )}
            <div class="p-6 flex flex-col flex-1">
              <h3 class="text-base font-semibold text-foreground mb-3 group-hover:text-primary transition-colors">
                {project.data.title}
              </h3>
              <p class="text-sm text-muted mb-1">
                {project.data.date.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })}
              </p>

              <div class="flex flex-wrap gap-2 my-3">
                {project.data.tags.map((tag: string) => (
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-primary/15 text-primary select-none cursor-default">{tag}</span>
                ))}
              </div>

              <div class="mt-auto flex justify-end">
                <a href={`/portfolio/${project.id}`} class="text-sm text-primary hover:text-primary-bright font-medium inline-flex items-center gap-1 transition-colors">
                  View Details
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- View All Projects -->
      <div class="flex justify-center mt-12">
        <a href="/portfolio" class="btn-outline">
          View All My Projects
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
    </section>
</Layout>
